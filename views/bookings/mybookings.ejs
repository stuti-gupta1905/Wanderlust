<% layout("/layouts/boilerplate") %>

<h2 class="mt-4 mb-4 text-center">My Bookings</h2>

<% if(bookings.length === 0){ %>

<div class="text-center mt-5">
    <h4>No bookings yet!</h4>
    <p>Looks like you haven't booked any stays.</p>

    <a href="/listings" class="btn btn-dark">
        Explore Stays
    </a>
</div>

<% } else { %>

<div class="row">

<% bookings.forEach((booking)=>{ %>

<%
const today = new Date();

let displayStatus = booking.status;

if(
    booking.status !== "Cancelled" &&
    new Date(booking.checkOut) < today
){
    displayStatus = "Completed";
}
%>

<div class="col-md-6 col-lg-4 mb-4">

<div class="card h-100 shadow-sm">

<img
class="card-img-top"
src="<%= booking.listing.image.url %>"
style="height:220px; object-fit:cover;"
>

<div class="card-body">

<h5 class="card-title">
<%= booking.listing.title %>
</h5>

<p class="text-muted mb-2">
<%= booking.listing.location %>,
<%= booking.listing.country %>
</p>

<p>
<b>Check In:</b><br>
<%= booking.checkIn.toLocaleDateString("en-IN") %>
</p>

<p>
<b>Check Out:</b><br>
<%= booking.checkOut.toLocaleDateString("en-IN") %>
</p>

<p>
<b>Guests:</b>
<%= booking.guests %>
</p>

<p>
<b>Total Price:</b>
₹<%= booking.totalPrice.toLocaleString("en-IN") %>
</p>

<p>
<b>Status:</b>

<% if(displayStatus==="Pending Payment"){ %>

<span class="badge bg-warning text-dark">
Pending Payment
</span>

<% } else if(displayStatus==="Completed"){ %>

<span class="badge bg-secondary">
Completed
</span>

<% } else if(displayStatus==="Confirmed"){ %>

<span class="badge bg-success">
Confirmed
</span>

<% } else { %>

<span class="badge bg-danger">
Cancelled
</span>

<% } %>

</p>

<div class="d-grid gap-2">

<a
href="/listings/<%= booking.listing._id %>"
class="btn btn-outline-dark"
>
View Listing
</a>

<% if(displayStatus === "Pending Payment"){ %>

<form
method="POST"
action="/bookings/<%= booking._id %>/cancel?_method=PUT"
>

<button class="btn btn-danger w-100">
Cancel Booking
</button>

</form>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<% } %>